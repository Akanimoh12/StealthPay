# ---------------------------------------------------------------------------
# StealthPay — environment variables
# Copy this file to `.env.local` and fill in the values from your Supabase
# project: Project Settings → API.
# ---------------------------------------------------------------------------

# Public project URL (safe to expose to the browser).
# Example: https://abcdefghijklmnop.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# Service role key — SERVER-SIDE ONLY. Never prefix with NEXT_PUBLIC_.
# This key bypasses Row Level Security; it is used only inside the
# /api/waitlist route handler to insert waitlist signups.
SUPABASE_SERVICE_ROLE_KEY=
