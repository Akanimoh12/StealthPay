# ---------------------------------------------------------------------------
# StealthPay — environment variables
# Copy this file to `.env.local` and fill in the values.
# ---------------------------------------------------------------------------

# --- Stacks contract (public, safe to expose to the browser) ---------------

# Deployed stealth-payroll contract principal, e.g.
#   ST1PQHQKV0RJXZFY1DGX8MNSNYVE3VGZJSRTPGZGM.stealth-payroll
# Use `<deployer-address>.stealth-payroll` from your testnet deployment.
NEXT_PUBLIC_CONTRACT_ADDRESS=

# The mock USDCx SIP-010 token deployed alongside the contract, e.g.
#   ST1PQHQKV0RJXZFY1DGX8MNSNYVE3VGZJSRTPGZGM.mock-usdcx
NEXT_PUBLIC_MOCK_USDCX_ADDRESS=

# The sBTC SIP-010 token principal on the target network (optional; if unset
# the sBTC option is disabled in the UI). Testnet sBTC:
#   ST1F7QA2MDF17S807EPA36TSS8AMEFY4KA9TVGWXT.sbtc-token
NEXT_PUBLIC_SBTC_ADDRESS=

# Target network: "testnet" | "mainnet" | "devnet". Keep testnet until audited.
NEXT_PUBLIC_NETWORK=testnet

# --- Supabase (waitlist only — NEVER store salaries or nonces here) --------

# Public project URL (safe to expose to the browser).
# Example: https://abcdefghijklmnop.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# Service role key — SERVER-SIDE ONLY. Never prefix with NEXT_PUBLIC_.
# This key bypasses Row Level Security; it is used only inside the
# /api/waitlist route handler to insert waitlist signups.
SUPABASE_SERVICE_ROLE_KEY=
